# Copy this file to .env and fill in your values
# cp .env.example .env

# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database Selection
# Set to True to use PostgreSQL, False to use SQLite
USE_POSTGRES=False

# PostgreSQL Database Configuration (only used if USE_POSTGRES=True)
# Install PostgreSQL: https://www.postgresql.org/download/
# After installation, create database and use these credentials:
DB_NAME=retail_basket_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
