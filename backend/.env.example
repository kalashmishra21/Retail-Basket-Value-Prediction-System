# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database Settings
USE_POSTGRES=True
DB_NAME=retail_basket_db
DB_USER=postgres
DB_PASSWORD=your-secure-password
DB_HOST=db
DB_PORT=5432

# Alternative: Use DATABASE_URL for Heroku/Render
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# CORS Settings (comma-separated list)
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Email Settings (Brevo/Sendinblue)
BREVO_API_KEY=your-brevo-api-key-here
BREVO_EMAIL=your-verified-sender-email@example.com
