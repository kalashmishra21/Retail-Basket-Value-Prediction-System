   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 🧹 Step 4: Data Cleaning"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create a copy for cleaning\n",
    "df_clean = df.copy()\n",
    "\n",
    "print(\"🧹 Starting Data Cleaning...\")\n",
    "print(f\"Initial records: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 1: Remove rows with missing CustomerID\n",
    "# Why: CustomerID is essential for customer-level analysis\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean.dropna(subset=['CustomerID'])\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} rows with missing CustomerID\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 2: Remove rows with missing Description\n",
    "# Why: Description helps identify product categories\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean.dropna(subset=['Description'])\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} rows with missing Description\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 3: Remove cancelled transactions (InvoiceNo starting with 'C')\n",
    "# Why: Cancelled orders don't represent actual purchases\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean[~df_clean['InvoiceNo'].astype(str).str.startswith('C')]\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} cancelled transactions\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 4: Remove rows with Quantity <= 0\n",
    "# Why: Negative/zero quantities are returns or data errors\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean[df_clean['Quantity'] > 0]\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} rows with Quantity <= 0\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  }
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 5: Remove rows with UnitPrice <= 0\n",
    "# Why: Zero/negative prices are data errors or free items\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean[df_clean['UnitPrice'] > 0]\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} rows with UnitPrice <= 0\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Step 6: Remove duplicate rows\n",
    "# Why: Duplicates can skew analysis and model training\n",
    "before = len(df_clean)\n",
    "df_clean = df_clean.drop_duplicates()\n",
    "removed = before - len(df_clean)\n",
    "print(f\"\\n✅ Removed {removed:,} duplicate rows\")\n",
    "print(f\"   Remaining: {len(df_clean):,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Summary of cleaning\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"📊 DATA CLEANING SUMMARY\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Original records: {len(df):,}\")\n",
    "print(f\"Cleaned records: {len(df_clean):,}\")\n",
    "print(f\"Records removed: {len(df) - len(df_clean):,}\")\n",
    "print(f\"Retention rate: {len(df_clean)/len(df)*100:.2f}%\")\n",
    "print(\"=\"*60)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## ⚙️ Step 5: Feature Engineering\n",
    "\n",
    "### 5.1 Date/Time Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Convert InvoiceDate to datetime\n",
    "# Why: Enables extraction of time-based features\n",
    "df_clean['InvoiceDate'] = pd.to_datetime(df_clean['InvoiceDate'])\n",
    "\n",
    "print(\"✅ InvoiceDate converted to datetime format\")\n",
    "print(f\"\\nDate Range: {df_clean['InvoiceDate'].min()} to {df_clean['InvoiceDate'].max()}\")"
   ]
  }
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Extract time-based features\n",
    "# Why: Time patterns affect customer purchasing behavior\n",
    "\n",
    "# Hour of day (0-23)\n",
    "df_clean['hour'] = df_clean['InvoiceDate'].dt.hour\n",
    "\n",
    "# Day of week (0=Monday, 6=Sunday)\n",
    "df_clean['day_of_week'] = df_clean['InvoiceDate'].dt.dayofweek\n",
    "\n",
    "# Month (1-12)\n",
    "df_clean['month'] = df_clean['InvoiceDate'].dt.month\n",
    "\n",
    "# Year\n",
    "df_clean['year'] = df_clean['InvoiceDate'].dt.year\n",
    "\n",
    "# Day of month (1-31)\n",
    "df_clean['day'] = df_clean['InvoiceDate'].dt.day\n",
    "\n",
    "print(\"✅ Time-based features created:\")\n",
    "print(\"   - hour (0-23)\")\n",
    "print(\"   - day_of_week (0-6)\")\n",
    "print(\"   - month (1-12)\")\n",
    "print(\"   - year\")\n",
    "print(\"   - day (1-31)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create binary features for time patterns\n",
    "# Why: Simplifies patterns for model learning\n",
    "\n",
    "# Is weekend? (Saturday=5, Sunday=6)\n",
    "df_clean['is_weekend'] = (df_clean['day_of_week'] >= 5).astype(int)\n",
    "\n",
    "# Is peak hour? (10 AM - 3 PM)\n",
    "df_clean['is_peak_hour'] = ((df_clean['hour'] >= 10) & (df_clean['hour'] <= 15)).astype(int)\n",
    "\n",
    "# Is morning? (6 AM - 12 PM)\n",
    "df_clean['is_morning'] = ((df_clean['hour'] >= 6) & (df_clean['hour'] < 12)).astype(int)\n",
    "\n",
    "# Is afternoon? (12 PM - 6 PM)\n",
    "df_clean['is_afternoon'] = ((df_clean['hour'] >= 12) & (df_clean['hour'] < 18)).astype(int)\n",
    "\n",
    "# Is evening? (6 PM - 10 PM)\n",
    "df_clean['is_evening'] = ((df_clean['hour'] >= 18) & (df_clean['hour'] < 22)).astype(int)\n",
    "\n",
    "print(\"\\n✅ Binary time features created:\")\n",
    "print(\"   - is_weekend (0/1)\")\n",
    "print(\"   - is_peak_hour (0/1)\")\n",
    "print(\"   - is_morning (0/1)\")\n",
    "print(\"   - is_afternoon (0/1)\")\n",
    "print(\"   - is_evening (0/1)\")"
   ]
  }
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.2 Transaction-Level Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate TotalPrice (Quantity × UnitPrice)\n",
    "# Why: This is the actual amount spent per line item\n",
    "df_clean['TotalPrice'] = df_clean['Quantity'] * df_clean['UnitPrice']\n",
    "\n",
    "print(\"✅ TotalPrice feature created\")\n",
    "print(f\"\\n💰 TotalPrice Statistics:\")\n",
    "print(f\"   Mean: £{df_clean['TotalPrice'].mean():.2f}\")\n",
    "print(f\"   Median: £{df_clean['TotalPrice'].median():.2f}\")\n",
    "print(f\"   Max: £{df_clean['TotalPrice'].max():.2f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.3 Invoice-Level Aggregation (Basket-Level Features)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Group by InvoiceNo to create basket-level features\n",
    "# Why: Our goal is to predict basket value, not individual item value\n",
    "\n",
    "invoice_features = df_clean.groupby('InvoiceNo').agg({\n",
    "    'TotalPrice': 'sum',           # Total basket value (TARGET VARIABLE)\n",
    "    'Quantity': 'sum',             # Total items in basket\n",
    "    'StockCode': 'count',          # Number of unique line items\n",
    "    'CustomerID': 'first',         # Customer who made purchase\n",
    "    'Country': 'first',            # Country of purchase\n",
    "    'InvoiceDate': 'first',        # Date of purchase\n",
    "    'hour': 'first',               # Hour of purchase\n",
    "    'day_of_week': 'first',        # Day of week\n",
    "    'month': 'first',              # Month\n",
    "    'year': 'first',               # Year\n",
    "    'is_weekend': 'first',         # Weekend flag\n",
    "    'is_peak_hour': 'first',       # Peak hour flag\n",
    "    'is_morning': 'first',         # Morning flag\n",
    "    'is_afternoon': 'first',       # Afternoon flag\n",
    "    'is_evening': 'first'          # Evening flag\n",
    "}).reset_index()\n",
    "\n",
    "# Rename columns for clarity\n",
    "invoice_features.rename(columns={\n",
    "    'TotalPrice': 'basket_value',\n",
    "    'Quantity': 'total_quantity',\n",
    "    'StockCode': 'num_items'\n",
    "}, inplace=True)\n",
    "\n",
    "print(\"✅ Invoice-level features aggregated\")\n",
    "print(f\"\\n📊 Total Invoices: {len(invoice_features):,}\")\n",
    "print(f\"\\n📋 Basket-level features:\")\n",
    "print(invoice_features.columns.tolist())"
   ]
  }
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.4 Customer-Level Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate customer-level statistics\n",
    "# Why: Customer history helps predict future behavior\n",
    "\n",
    "customer_stats = invoice_features.groupby('CustomerID').agg({\n",
    "    'basket_value': ['mean', 'sum', 'count'],  # Average, total, and count of purchases\n",
    "    'total_quantity': 'mean',                   # Average items per purchase\n",
    "    'num_items': 'mean'                         # Average unique items per purchase\n",
    "}).reset_index()\n",
    "\n",
    "# Flatten column names\n",
    "customer_stats.columns = ['CustomerID', 'avg_basket_value', 'total_spent', \n",
    "                          'purchase_count', 'avg_quantity', 'avg_unique_items']\n",
    "\n",
    "print(\"✅ Customer-level features created:\")\n",
    "print(\"   - avg_basket_value: Average spending per purchase\")\n",
    "print(\"   - total_spent: Total amount spent by customer\")\n",
    "print(\"   - purchase_count: Number of purchases made\")\n",
    "print(\"   - avg_quantity: Average items per purchase\")\n",
    "print(\"   - avg_unique_items: Average unique products per purchase\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Merge customer stats back to invoice features\n",
    "# Why: Each invoice needs customer history for prediction\n",
    "invoice_features = invoice_features.merge(customer_stats, on='CustomerID', how='left')\n",
    "\n",
    "print(\"\\n✅ Customer features merged to invoice data\")\n",
    "print(f\"Final dataset shape: {invoice_features.shape}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.5 Derived Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate average price per item in basket\n",
    "# Why: Indicates if customer buys expensive or cheap items\n",
    "invoice_features['avg_item_price'] = (invoice_features['basket_value'] / \n",
    "                                       invoice_features['total_quantity'])\n",
    "\n",
    "# Calculate item diversity (unique items / total quantity)\n",
    "# Why: Shows if customer buys many different items or repeats same items\n",
    "invoice_features['item_diversity'] = (invoice_features['num_items'] / \n",
    "                                       invoice_features['total_quantity'])\n",
    "\n",
    "print(\"✅ Derived features created:\")\n",
    "print(\"   - avg_item_price: Average price per item in basket\")\n",
    "print(\"   - item_diversity: Ratio of unique items to total quantity\")"
   ]
  }
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.6 Customer Loyalty/Segmentation Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create customer loyalty score (0-1 scale)\n",
    "# Why: Loyal customers tend to spend more\n",
    "# Formula: Normalize purchase_count to 0-1 range\n",
    "\n",
    "max_purchases = invoice_features['purchase_count'].max()\n",
    "invoice_features['customer_loyalty'] = (invoice_features['purchase_count'] / max_purchases)\n",
    "\n",
    "print(\"✅ Customer loyalty score created (0-1 scale)\")\n",
    "print(f\"\\n📊 Loyalty Score Distribution:\")\n",
    "print(invoice_features['customer_loyalty'].describe())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Categorize customers into segments\n",
    "# Why: Different customer segments have different spending patterns\n",
    "\n",
    "def categorize_customer(loyalty_score):\n",
    "    if loyalty_score >= 0.7:\n",
    "        return 'High'      # Highly loyal customers\n",
    "    elif loyalty_score >= 0.3:\n",
    "        return 'Medium'    # Moderately loyal customers\n",
    "    else:\n",
    "        return 'Low'       # New or infrequent customers\n",
    "\n",
    "invoice_features['customer_segment'] = invoice_features['customer_loyalty'].apply(categorize_customer)\n",
    "\n",
    "print(\"\\n✅ Customer segments created:\")\n",
    "print(invoice_features['customer_segment'].value_counts())"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.7 Country/Location Features"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create binary feature for UK vs International\n",
    "# Why: UK customers may have different spending patterns\n",
    "invoice_features['is_uk'] = (invoice_features['Country'] == 'United Kingdom').astype(int)\n",
    "\n",
    "print(\"✅ Location feature created:\")\n",
    "print(f\"   UK customers: {invoice_features['is_uk'].sum():,}\")\n",
    "print(f\"   International customers: {(1-invoice_features['is_uk']).sum():,}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Encode Country using Label Encoding\n",
    "# Why: ML models need numerical representation of categories\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "le_country = LabelEncoder()\n",
    "invoice_features['country_encoded'] = le_country.fit_transform(invoice_features['Country'])\n",
    "\n",
    "print(\"\\n✅ Country encoded to numerical values\")\n",
    "print(f\"   Unique countries: {invoice_features['Country'].nunique()}\")"
   ]
  }
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### 5.8 Recency Feature"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate days since last purchase for each customer\n",
    "# Why: Recent customers are more likely to make repeat purchases\n",
    "\n",
    "# Get the latest date in dataset\n",
    "max_date = invoice_features['InvoiceDate'].max()\n",
    "\n",
    "# Calculate recency (days since last purchase)\n",
    "invoice_features['recency_days'] = (max_date - invoice_features['InvoiceDate']).dt.days\n",
    "\n",
    "print(\"✅ Recency feature created\")\n",
    "print(f\"\\n📅 Recency Statistics:\")\n",
    "print(f\"   Mean: {invoice_features['recency_days'].mean():.2f} days\")\n",
    "print(f\"   Median: {invoice_features['recency_days'].median():.0f} days\")\n",
    "print(f\"   Max: {invoice_features['recency_days'].max()} days\")"
   ]
  },
  {
